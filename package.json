{
  "name": "fransizca-ogren",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "migrate": "node scripts/migrate.mjs",
    "sync": "node scripts/sync.mjs",
    "audio": "node scripts/audio.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:app": "vitest run src/utils",
    "test:data": "vitest run src/tests/data.test.js",
    "deploy": "npm run test && npm run build && node scripts/deploy.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:iphone": "playwright test --project=\"iPhone 15 Plus\"",
    "test:desktop": "playwright test --project=\"Desktop Chrome\"",
    "test:headed": "playwright test --headed --project=\"iPhone 15 Plus\""
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
